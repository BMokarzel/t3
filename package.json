{
  "name": "t3",
  "version": "0.1.0",
  "description": "Biblioteca do fluxo de enrollment do Digital Advisor (arquitetura hexagonal).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contract/index.d.ts",
      "default": "./dist/contract/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
